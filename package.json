{
  "name": "swimlane-logicflow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ui": "vite",
    "dev:api": "apps/api/.venv/bin/python -m uvicorn app.main:app --app-dir apps/api --reload --port 8000",
    "test:ui-mock": "vitest run",
    "test:api-mock": "PYTHONPATH=apps/api apps/api/.venv/bin/python -m pytest apps/api/tests --ignore=apps/api/tests/test_live_smoke.py",
    "test:e2e-mock": "playwright test",
    "test:brd-mock": "npm run test:ui-mock && npm run test:api-mock && npm run test:e2e-mock",
    "test:api-live": "PYTHONPATH=apps/api apps/api/.venv/bin/python -m pytest apps/api/tests/test_live_smoke.py -q -rs",
    "api:python:smoke": "apps/api/.venv/bin/python -c \"import alembic, clerk_backend_api, sqlalchemy\"",
    "db:migrate": "cd apps/api && .venv/bin/python -m alembic upgrade head",
    "db:downgrade": "cd apps/api && .venv/bin/python -m alembic downgrade -1",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@clerk/react": "^6.7.3",
    "@logicflow/core": "^1.2.27",
    "@logicflow/extension": "^1.2.27",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
